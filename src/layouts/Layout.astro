---
import "normalize.css";
import "../assets/styles/global.scss";
import type { Lang } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
	lang: Lang;
}

const { lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const localeMap = { en: 'en_US', fr: 'fr_FR', es: 'es_ES' };
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<!-- FAVICON -->
		<link rel="icon" type="image/png" href={`${base}/favicon-96x96.png`} sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<link rel="shortcut icon" href={`${base}/favicon.ico`} />
		<link rel="apple-touch-icon" sizes="180x180" href={`${base}/apple-touch-icon.png`} />
		<link rel="manifest" href={`${base}/site.webmanifest`} />
		<!-- END FAVICON -->
		<meta name="generator" content={Astro.generator} />
		<title>{t(lang, 'meta.title')}</title>
		<meta name="description" content={t(lang, 'meta.description')} />
		<link rel="canonical" href={`https://www.kelx.fr/${lang}/`} />
		<link rel="alternate" hreflang="en" href="https://www.kelx.fr/en/" />
		<link rel="alternate" hreflang="fr" href="https://www.kelx.fr/fr/" />
		<link rel="alternate" hreflang="es" href="https://www.kelx.fr/es/" />
		<link rel="alternate" hreflang="x-default" href="https://www.kelx.fr/en/" />
		<meta property="og:locale" content={localeMap[lang]} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={t(lang, 'meta.title')} />
		<meta property="og:description" content={t(lang, 'meta.description')} />
		<meta property="og:url" content={`https://www.kelx.fr/${lang}/`} />
		<meta property="og:site_name" content="KELX" />
		<meta name="twitter:card" content="summary_large_image" />
		
		<!-- FONTS -->
		<link rel="preload" href={`${base}/fonts/ClashGrotesk/ClashGrotesk-Variable.woff2`} as="font" type="font/woff2" crossorigin />
		<link rel="preload" href={`${base}/fonts/Inconsolata/Inconsolata-VariableFont_wdth,wght.ttf`} as="font" type="font/ttf" crossorigin />
		<!-- END FONTS -->
	</head>
	<body>
		<slot />
	</body>
</html>

