---
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import skillsData from '../data/skills.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---
<section id="skills" class="skills wrapper">
    <h2 class="section-title">{t(lang, 'skills.title')}</h2>
    <div class="skills-grid">
        {skillsData.categories.map((category) => (
            <div class="skill-category">
                <h3 class="category-name">{category.name[lang]}</h3>
                <ul class="skill-list">
                    {category.skills.map((skill) => (
                        <li class="skill-item">
                            <div class="skill-header">
                                <span class="skill-name">{skill.name}</span>
                            </div>
                            <div class="skill-bar">
                                <div class="skill-fill" style={`width: ${skill.level}%`}></div>
                            </div>
                        </li>
                    ))}
                </ul>
            </div>
        ))}
    </div>
</section>

<style lang="scss">
@use '../assets/styles/breakpoints' as *;

.skills {
    padding: 5rem 20px;

    .skills-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2.5rem;
        margin-top: 2rem;

        @include to(tablet) {
            grid-template-columns: 1fr;
        }
    }

    .skill-category {
        padding: 1.5rem;
        border-radius: 8px;
        background: rgba(103, 70, 54, 0.03);
        border: 1px solid rgba(103, 70, 54, 0.08);
    }

    .category-name {
        font-family: var(--font-primary);
        font-size: 1rem;
        font-weight: 600;
        margin: 0 0 1.25rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid var(--color-primary);
    }

    .skill-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .skill-item {
        margin-bottom: 0.9rem;

        &:last-child {
            margin-bottom: 0;
        }
    }

    .skill-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.3rem;
    }

    .skill-name {
        font-family: var(--font-secondary);
        font-size: 0.82rem;
        font-weight: 400;
        font-stretch: 110%;
    }

    .skill-bar {
        width: 100%;
        height: 4px;
        background: rgba(103, 70, 54, 0.1);
        border-radius: 2px;
        overflow: hidden;
    }

    .skill-fill {
        height: 100%;
        background: var(--color-primary);
        border-radius: 2px;
        transition: width 0.8s ease;
    }
}
</style>
