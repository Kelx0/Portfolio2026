---
import { t, languages, getLocalizedUrl } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const date = new Date();
---
<header class="header wrapper">
    <a href={getLocalizedUrl(lang)} class="logo">
        <span class="title">KELX</span>
    </a>
    <nav>
        <ul>
            <li><a href={`${base}/${lang}/#hero`}>{t(lang, 'nav.home')}</a></li>
            <li><a href={`${base}/${lang}/#about`}>{t(lang, 'nav.about')}</a></li>
            <li><a href={`${base}/${lang}/#experience`}>{t(lang, 'nav.experience')}</a></li>
            <li><a href={`${base}/${lang}/#projects`}>{t(lang, 'nav.projects')}</a></li>
            <li><a href={`${base}/${lang}/#skills`}>{t(lang, 'nav.skills')}</a></li>
            <li><a href={`${base}/${lang}/#contact`}>{t(lang, 'nav.contact')}</a></li>
        </ul>
    </nav>
    <div class="header-right">
        <div class="lang-switcher">
            {Object.entries(languages).map(([code, label]) => (
                <a
                    href={`${base}/${code}/`}
                    class:list={['lang-link', { active: code === lang }]}
                    aria-label={label}
                >
                    {code.toUpperCase()}
                </a>
            ))}
        </div>
    </div>
</header>

<style lang="scss">
@use '../assets/styles/breakpoints' as *;

.header{
    padding:20px 10px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;

   .logo{
    text-decoration: none;
    color: var(--color-primary);
     .title{
        font-family: var(--font-primary);
        font-size: 16px;
        font-weight: 700;
    }
   }

    nav{
        @include to(tablet) {
            display: none;
        }
        ul{
            list-style: none;
            display: flex;
            gap: 1.5rem;
            padding: 0;
            margin: 0;

            li{
                a{
                    text-decoration: none;
                    color: inherit;
                    font-family: var(--font-secondary);
                    font-size: 13px;
                    font-weight: 300;
                    font-stretch: 130%;
                    text-transform: uppercase;
                    transition: all 0.3s ease-in-out;

                    &::after{
                        content: '';
                        display: block;
                        width: 0;
                        height: 2px;
                        background: currentColor;
                        transition: width 0.3s ease-in-out;
                    }
                    
                    &:hover, &:active{
                        font-weight: 700;
                        font-stretch: 120%;
                        &::after{
                            width: 100%;
                        }
                    }
                }
            }
        }
    }

    .header-right{
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .lang-switcher{
        display: flex;
        gap: 0.25rem;

        .lang-link{
            text-decoration: none;
            color: var(--color-primary);
            font-family: var(--font-secondary);
            font-size: 12px;
            font-weight: 400;
            padding: 2px 6px;
            border-radius: 3px;
            transition: all 0.2s ease;
            opacity: 0.5;

            &.active{
                opacity: 1;
                font-weight: 700;
                background: var(--color-primary);
                color: var(--color-background);
            }

            &:hover:not(.active){
                opacity: 0.8;
            }
        }
    }

    .year{
        font-family: var(--font-secondary);
        font-size: 14px;
        font-weight: 700;
        font-stretch: 120%;

        @include to(tablet) {
            display: none;
        }
    }
}
</style>