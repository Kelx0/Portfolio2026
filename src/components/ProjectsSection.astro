---
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import projects from '../data/projects.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<section id="projects" class="projects wrapper">
    <h2 class="section-title">{t(lang, 'projects.title')}</h2>
    <div class="projects-grid">
        {projects.map((project) => (
            <article class="project-card">
                <div class="card-image">
                    {project.image ? (
                        <img src={`${base}${project.image}`} alt={project.title} loading="lazy" />
                    ) : (
                        <div class="card-placeholder"></div>
                    )}
                </div>
                <div class="card-body">
                    <h3 class="card-title">{project.title}</h3>
                    <p class="card-desc">{project.description[lang]}</p>
                    <div class="card-tags">
                        {project.tags.map((tag: string) => (
                            <span class="tag">{tag}</span>
                        ))}
                    </div>
                    <div class="card-links">
                        {project.url && (
                            <a href={project.url} target="_blank" rel="noopener" class="card-link">
                                {t(lang, 'projects.viewProject')} ↗
                            </a>
                        )}
                        {project.github && (
                            <a href={project.github} target="_blank" rel="noopener" class="card-link">
                                {t(lang, 'projects.viewCode')} ↗
                            </a>
                        )}
                    </div>
                </div>
            </article>
        ))}
    </div>
</section>

<style lang="scss">
@use '../assets/styles/breakpoints' as *;

.projects {
    padding: 5rem 20px;

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
        margin-top: 2rem;

        @include to(desktop) {
            grid-template-columns: repeat(2, 1fr);
        }

        @include to(tablet) {
            grid-template-columns: 1fr;
        }
    }

    .project-card {
        border: 1px solid var(--color-primary);
        border-radius: 10px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .card-image {
        width: 100%;
        height: 180px;
        overflow: hidden;

        img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
    }

    .card-placeholder {
        width: 100%;
        height: 100%;
        background: #D5D5D5;
    }

    .card-body {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
    }

    .card-title {
        font-family: var(--font-primary);
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--color-primary);
        margin: 0 0 0.4rem;
    }

    .card-desc {
        font-family: var(--font-secondary);
        font-size: 0.8rem;
        font-weight: 300;
        font-stretch: 110%;
        line-height: 1.5;
        color: var(--color-primary);
        opacity: 0.75;
        margin: 0 0 0.75rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
        margin-bottom: 0.75rem;

        .tag {
            font-family: var(--font-secondary);
            font-size: 0.58rem;
            font-weight: 600;
            padding: 0.15rem 0.45rem;
            border-radius: 3px;
            border: 1px solid var(--color-primary);
            color: var(--color-primary);
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
    }

    .card-links {
        display: flex;
        gap: 1.25rem;
    }

    .card-link {
        font-family: var(--font-secondary);
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--color-primary);
        text-decoration: none;
        transition: opacity 0.2s ease;

        &:hover {
            opacity: 0.6;
        }
    }
}
</style>
