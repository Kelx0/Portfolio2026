---
import { getLocalizedData } from '../i18n/utils';
import { t } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import profile from '../data/profile.json';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---
<section id="hero" class="hero wrapper">
    <div class="hero-content">
        <p class="hero-greeting">{t(lang, 'hero.greeting')}</p>
        <h1 class="hero-name">{profile.name}</h1>
        <h2 class="hero-title">{getLocalizedData(profile.title, lang)}</h2>
        <p class="hero-subtitle">{profile.subtitle[lang]}</p>
        <p class="hero-location">{profile.location[lang]}</p>
        <div class="hero-cta">
            <a href={`/${lang}/#projects`} class="btn btn-primary">{t(lang, 'hero.cta')}</a>
            {profile.resumeUrl[lang] && (
                <a href={profile.resumeUrl[lang]} class="btn btn-outline" target="_blank" rel="noopener">
                    {t(lang, 'hero.downloadCv')}
                </a>
            )}
        </div>
    </div>
    <div class="hero-right">
        <div class="hero-photo">
            <img src="/images/profile.png" alt={profile.name} width="280" height="280" loading="eager" />
        </div>
        <div class="hero-badge">
            <span class="badge-text">{profile.availability[lang]}</span>
        </div>
    </div>
</section>

<style lang="scss">
@use '../assets/styles/breakpoints' as *;

.hero {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 4rem;
    padding-bottom: 4rem;
    gap: 2rem;

    @include to(tablet) {
        flex-direction: column;
        min-height: 60vh;
        text-align: center;
        padding-top: 3rem;
    }

    .hero-content {
        max-width: 700px;
    }

    .hero-greeting {
        font-family: var(--font-secondary);
        font-size: 1rem;
        font-weight: 400;
        margin: 0 0 0.5rem;
        opacity: 0.7;
    }

    .hero-name {
        font-family: var(--font-primary);
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: 700;
        line-height: 1.1;
        margin: 0 0 0.5rem;
    }

    .hero-title {
        font-family: var(--font-primary);
        font-size: clamp(1.2rem, 3vw, 1.8rem);
        font-weight: 400;
        margin: 0 0 1rem;
        opacity: 0.8;
    }

    .hero-subtitle {
        font-family: var(--font-secondary);
        font-size: 0.9rem;
        font-weight: 300;
        font-stretch: 120%;
        letter-spacing: 0.05em;
        margin: 0 0 0.5rem;
        opacity: 0.6;
    }

    .hero-location {
        font-family: var(--font-secondary);
        font-size: 0.85rem;
        margin: 0 0 2rem;
        opacity: 0.5;
    }

    .hero-cta {
        display: flex;
        gap: 1rem;

        @include to(tablet) {
            justify-content: center;
        }
    }

    .hero-right {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;

        @include to(tablet) {
            order: -1;
        }
    }

    .hero-photo {
        width: 280px;
        height: 280px;
        border-radius: 8px;
        overflow: hidden;

        img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: grayscale(20%);
            transition: filter 0.3s ease;

            &:hover {
                filter: grayscale(0%);
            }
        }

        @include to(tablet) {
            width: 200px;
            height: 200px;
        }
    }

    .hero-badge {
        background: var(--color-primary);
        color: var(--color-background);
        padding: 0.75rem 1.25rem;
        border-radius: 6px;
        max-width: 220px;
        text-align: center;

        .badge-text {
            font-family: var(--font-secondary);
            font-size: 0.8rem;
            font-weight: 500;
            line-height: 1.4;
        }
    }
}

.btn {
    display: inline-block;
    font-family: var(--font-secondary);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.btn-primary {
    background: var(--color-primary);
    color: var(--color-background);

    &:hover {
        opacity: 0.9;
        transform: translateY(-2px);
    }
}

.btn-outline {
    border: 1.5px solid var(--color-primary);
    color: var(--color-primary);
    background: transparent;

    &:hover {
        background: var(--color-primary);
        color: var(--color-background);
        transform: translateY(-2px);
    }
}
</style>
